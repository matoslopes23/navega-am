generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model HealthCheck {
  id        String   @id @default(uuid())
  status    String
  createdAt DateTime @default(now())
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  phone        String?  @unique
  cpf          String   @unique
  passwordHash String
  role         UserRole @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  trackingParticipations TrackingParticipant[]
  tripReports            TripReport[]
}

model Trip {
  id                String          @id @default(uuid())
  boatName          String
  boatType          String
  price             Int
  origin            String
  destination       String
  departureDate     DateTime
  departureTime     String
  userDepartureDate DateTime?
  userDepartureTime String?
  status            TripStatus      @default(programado)
  
  // Guardam apenas a ÚLTIMA posição calculada para consultas rápidas via HTTP GET
  latitude          Float
  longitude         Float
  lastPositionAt    DateTime?
  originLatitude    Float?
  originLongitude   Float?
  destinationLatitude  Float?
  destinationLongitude Float?
  confidenceLevel   ConfidenceLevel @default(BAIXO) // Adicionado para refletir o infográfico
  
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  itineraries       Itinerary[]
  accommodations    Accommodation[]
  
  // Relacionamentos para telemetria (Novos)
  rawLocations      RawLocation[]
  boatLocations     BoatLocation[]
  trackingParticipants TrackingParticipant[]
  reports           TripReport[]

  @@index([origin, destination])
  @@index([departureDate])
}

model Itinerary {
  id          String        @id @default(uuid())
  tripId      String
  name        String
  type        ItineraryType
  time        String
  description String
  status      String?
  order       Int
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  trip        Trip          @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@index([order])
}

model Accommodation {
  id          String   @id @default(uuid())
  tripId      String
  name        String
  price       Int
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
}

model RawLocation {
  id        String   @id @default(uuid())
  tripId    String
  deviceId  String   // Hash anônimo enviado pelo React Native para distinguir passageiros
  latitude  Float
  longitude Float
  pingedAt  DateTime // Data/Hora exata em que o celular capturou o GPS (essencial para dados offline)
  clientPointId String?
  accuracy      Float?
  speed         Float?
  heading       Float?
  createdAt DateTime @default(now())

  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@index([pingedAt]) // Otimiza a query do Worker de buscar os últimos 5 minutos
  @@unique([tripId, deviceId, clientPointId])
}

model BoatLocation {
  id              String          @id @default(uuid())
  tripId          String
  latitude        Float
  longitude       Float
  confidenceLevel ConfidenceLevel
  calculatedAt    DateTime        @default(now())
  contributorCount Int            @default(1)
  speedKmh         Float?
  progressPercent  Float?
  remainingDistanceKm Float?
  estimatedArrival DateTime?

  trip            Trip            @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
}

model TrackingParticipant {
  id         String   @id @default(uuid())
  tripId     String
  userId     String
  active     Boolean  @default(true)
  startedAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())
  stoppedAt  DateTime?

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tripId, userId])
  @@index([tripId, active, lastSeenAt])
}

model TripReport {
  id          String           @id @default(uuid())
  tripId      String
  userId      String
  type        TripReportType
  description String?
  latitude    Float?
  longitude   Float?
  status      TripReportStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tripId, status, createdAt])
}

// ==========================================
// ENUMS
// ==========================================

enum TripStatus {
  em_transito
  no_porto
  programado
  embarcando
  concluido
  cancelado
  atrasado
}

enum ItineraryType {
  saida
  escala
  destino
}

// Novo Enum para o Nível de Confiança exibido na interface do usuário
enum ConfidenceLevel {
  ALTO
  MEDIO
  BAIXO
}

enum UserRole {
  USER
  ADMIN
}

enum TripReportType {
  DELAY
  STOPPED
  BREAKDOWN
  SAFETY
  MANUAL_POSITION
  OTHER
}

enum TripReportStatus {
  PENDING
  CONFIRMED
  REJECTED
}
